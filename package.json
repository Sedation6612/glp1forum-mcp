{
  "name": "glp1forum-mcp",
  "version": "0.3.1",
  "type": "module",
  "description": "MCP server to search & investigate glp1forum.com (XenForo) with no API keys",
  "keywords": ["mcp", "mcp-server", "model-context-protocol", "claude", "glp1", "xenforo", "forum", "scraper", "peptides"],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Sedation6612",
  "homepage": "https://github.com/Sedation6612/glp1forum-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sedation6612/glp1forum-mcp.git"
  },
  "bin": {
    "glp1forum-mcp": "dist/index.mjs"
  },
  "scripts": {
    "start": "node src/index.js",
    "selftest": "node src/selftest.js",
    "build": "esbuild src/index.js --bundle --platform=node --format=esm --packages=bundle --outfile=dist/index.mjs --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "pack": "npm run build && npx -y @anthropic-ai/mcpb pack"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cheerio": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "allowScripts": {
    "esbuild@0.24.2": true
  }
}
