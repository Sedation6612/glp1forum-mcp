{
  "manifest_version": "0.3",
  "name": "glp1forum-mcp",
  "display_name": "glp1forum.com Search",
  "version": "0.5.0",
  "description": "Search & read glp1forum.com (a XenForo forum) with no API keys, via system curl.",
  "author": { "name": "Sedation6612", "url": "https://github.com/Sedation6612" },
  "repository": { "type": "git", "url": "https://github.com/Sedation6612/glp1forum-mcp.git" },
  "homepage": "https://github.com/Sedation6612/glp1forum-mcp",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": ["mcp", "mcp-server", "model-context-protocol", "claude", "glp1", "xenforo", "forum", "scraper", "peptides"],
  "server": {
    "type": "node",
    "entry_point": "dist/index.mjs",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.mjs"]
    }
  },
  "compatibility": {
    "platforms": ["win32", "darwin", "linux"],
    "runtimes": { "node": ">=18.0.0" }
  }
}
